generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  price       Float
  stock       Int
  minStock    Int @default(5)

  createdAt   DateTime @default(now())

  saleItems   SaleItem[]
}

model Sale {
  id        String   @id @default(cuid())
  total     Float
  type      String   // "CASH" | "CREDIT"
  createdAt DateTime @default(now())

  items     SaleItem[]
}

model SaleItem {
  id        String   @id @default(cuid())
  quantity  Int
  price     Float

  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])

  productId String
  product   Product  @relation(fields: [productId], references: [id])
}

model Customer {
  id          String   @id @default(cuid())

  name        String
  phone       String?

  balance     Float @default(0)

  createdAt   DateTime @default(now())

  credits     Credit[]
}

model Credit {
  id          String   @id @default(cuid())
  amount      Float
  type        String   // DEBT | PAYMENT
  note        String?

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  saleId      String?

  createdAt   DateTime @default(now())
}

// enum CreditType {
//   DEBT
//   PAYMENT
// }

model CashSession {
  id            String   @id @default(cuid())

  date          DateTime @default(now())

  cashSales     Float    @default(0)
  creditSales   Float    @default(0)
  totalSales    Float    @default(0)

  expectedCash  Float    @default(0)
  actualCash    Float

  difference    Float

  createdAt     DateTime @default(now())
}